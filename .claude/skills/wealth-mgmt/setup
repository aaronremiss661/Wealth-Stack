#!/usr/bin/env bash
# wealthstack setup — install wealth management skills for Claude Code
set -e

WEALTHSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$HOME/.claude/skills"

echo ""
echo "  WealthStack v$(cat "$WEALTHSTACK_DIR/VERSION")"
echo "  AI-powered wealth management for Indian investors"
echo ""

# ─── Parse flags ──────────────────────────────────────────────
LOCAL_INSTALL=0
while [ $# -gt 0 ]; do
  case "$1" in
    --local) LOCAL_INSTALL=1; shift ;;
    --help|-h)
      echo "Usage: ./setup [--local]"
      echo ""
      echo "  --local    Install to .claude/skills/ in current directory (repo-local)"
      echo "             Default: install to ~/.claude/skills/ (global)"
      echo ""
      exit 0
      ;;
    *) shift ;;
  esac
done

if [ "$LOCAL_INSTALL" -eq 1 ]; then
  SKILLS_DIR="$(pwd)/.claude/skills"
fi

# ─── Check Python ──────────────────────────────────────────────
if ! command -v python3 >/dev/null 2>&1; then
  echo "Error: python3 is required but not installed." >&2
  exit 1
fi

# ─── Install yfinance ──────────────────────────────────────────
echo "Checking Python dependencies..."
if ! python3 -c "import yfinance" 2>/dev/null; then
  echo "Installing yfinance for market data..."
  pip3 install yfinance --quiet 2>/dev/null || pip install yfinance --quiet 2>/dev/null || {
    echo "Warning: Could not install yfinance. Market data features will use WebSearch fallback." >&2
  }
fi

# ─── Install skills ───────────────────────────────────────────
DEST="$SKILLS_DIR/wealthstack"
mkdir -p "$SKILLS_DIR"

if [ "$WEALTHSTACK_DIR" = "$DEST" ]; then
  echo "Already installed at $DEST"
else
  # Remove old install if present
  if [ -L "$DEST" ]; then
    rm "$DEST"
  elif [ -d "$DEST" ]; then
    rm -rf "$DEST"
  fi

  # Symlink for development, copy for production
  if [ -d "$WEALTHSTACK_DIR/.git" ]; then
    ln -s "$WEALTHSTACK_DIR" "$DEST"
    echo "Linked $WEALTHSTACK_DIR -> $DEST (dev mode)"
  else
    cp -r "$WEALTHSTACK_DIR" "$DEST"
    echo "Installed to $DEST"
  fi
fi

# ─── Make scripts executable ──────────────────────────────────
chmod +x "$DEST/bin/"*.sh 2>/dev/null || true

# ─── Initialize config ────────────────────────────────────────
echo "Initializing configuration..."
bash "$DEST/bin/wealth-config.sh" init

echo ""
echo "  Setup complete!"
echo ""
echo "  Available commands:"
echo "    /wealth-mgmt       — Overview of all capabilities"
echo "    /portfolio         — Analyze your portfolio"
echo "    /risk-assess       — Risk profiling & stress testing"
echo "    /tax-optimize      — Tax-loss harvesting & optimization"
echo "    /rebalance         — Portfolio rebalancing"
echo "    /client-report     — Generate client reports"
echo "    /market-brief      — Market research & analysis"
echo "    /compliance        — Regulatory compliance checks"
echo "    /financial-plan    — Retirement & financial planning"
echo ""
echo "  Quick start:"
echo "    1. Open Claude Code"
echo "    2. Type /portfolio to analyze your first portfolio"
echo ""
echo "  Defaults: INR | NSE | Nifty 50 benchmark | New tax regime"
echo "  Configure: bash ~/.claude/skills/wealthstack/bin/wealth-config.sh set <key> <value>"
echo ""
